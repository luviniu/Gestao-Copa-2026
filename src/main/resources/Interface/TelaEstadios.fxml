<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.ColorAdjust?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1080.0" prefWidth="1920.0" xmlns="http://javafx.com/javafx/25.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Interface.TelaEstadios">
   <children>
      <ImageView fitHeight="1080.0" fitWidth="1920.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../assets/stadium2.jpg" />
         </image>
         <effect>
            <GaussianBlur />
         </effect>
      </ImageView>

      <Rectangle id="background-capa" height="717.0" layoutX="620.0" layoutY="151.0" smooth="false" stroke="#2f1f1f" strokeType="INSIDE" strokeWidth="0.0" width="700.0">
         <effect>
            <ColorAdjust />
         </effect>
         <fill>
            <LinearGradient endX="1.0" endY="0.5142857142857142" startX="0.8047619047619048">
               <stops>
                  <Stop>
                     <color>
                        <Color red="0.0313725508749485" green="0.0470588244497776" blue="0.10588235408067703" />
                     </color>
                  </Stop>
                  <Stop offset="1.0">
                     <color>
                        <Color red="0.03" green="0.045" blue="0.1" opacity="0.56" />
                     </color>
                  </Stop>
               </stops>
            </LinearGradient>
         </fill>
      </Rectangle>

      <Text fill="#e7e7ee" layoutX="825.0" layoutY="215.0" strokeType="OUTSIDE" strokeWidth="0.0" text="GESTÃO DE ESTÁDIOS" textAlignment="CENTER">
         <font>
            <Font size="28.0" />
         </font>
      </Text>

      <TextField fx:id="txtBusca" layoutX="700.0" layoutY="250.0" prefHeight="35.0" prefWidth="540.0" promptText="🔍 Digite o nome ou local para pesquisar estádios instantaneamente..." />

      <TableView fx:id="tabelaEstadios" layoutX="700.0" layoutY="300.0" prefHeight="380.0" prefWidth="540.0">
         <columns>
            <TableColumn fx:id="colunaNome" prefWidth="180.0" text="Nome" />
            <TableColumn fx:id="colunaLocal" prefWidth="200.0" text="Local" />
            <TableColumn fx:id="colunaCapacidade" prefWidth="158.0" text="Capacidade" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>

      <HBox layoutX="700.0" layoutY="700.0" prefHeight="50.0" prefWidth="540.0" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleAdicionarEstadio" prefHeight="40.0" prefWidth="170.0" text="Adicionar Estádio" />
            <Button mnemonicParsing="false" onAction="#handleEditarEstadio" prefHeight="40.0" prefWidth="170.0" text="Alterar Informações" />
            <Button mnemonicParsing="false" onAction="#handleRemoverEstadio" prefHeight="40.0" prefWidth="170.0" text="Remover" />
            <Button mnemonicParsing="false" onAction="#voltarParaLauncher" prefHeight="40.0" prefWidth="170.0" text="Voltar" />
         </children>
      </HBox>
   </children>
   <cursor>
      <Cursor fx:constant="DEFAULT" />
   </cursor>
</AnchorPane>
