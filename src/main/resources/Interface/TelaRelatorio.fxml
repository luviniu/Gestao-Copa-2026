<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Interface.TelaRelatorio">

    <children>
        <ImageView fitHeight="1120.0" fitWidth="1753.0" layoutX="-52.0" layoutY="-9.0" pickOnBounds="true" preserveRatio="false">
            <image>
                <Image url="@../assets/stadium2.jpg" />
            </image>
            <effect>
                <GaussianBlur />
            </effect>
        </ImageView>
        <Rectangle id="background-capa" height="1125.0" layoutX="410.0" layoutY="-17.0" smooth="false" stroke="#2f1f1f" strokeType="INSIDE" strokeWidth="0.0" width="807.0">
            <effect>
                <ColorAdjust />
            </effect>
            <fill>
                <LinearGradient endX="1.0" endY="0.5142857142857142" startX="0.8047619047619048">
                    <stops>
                        <Stop>
                            <color>
                                <Color red="0.0313725508749485" green="0.0470588244497776" blue="0.10588235408067703" />
                            </color>
                        </Stop>
                        <Stop offset="1.0">
                            <color>
                                <Color red="0.029999999329447746" green="0.04516666755080223" blue="0.10000000149011612" opacity="0.5632184147834778" />
                            </color>
                        </Stop>
                    </stops>
                </LinearGradient>
            </fill>
        </Rectangle>

        <Label layoutX="561.0" layoutY="60.0" text="RELATÓRIO FINANCEIRO" textFill="WHITE">
            <font>
                <Font name="System Bold" size="41.0" />
            </font>
        </Label>

        <Label fx:id="lblArrecadacaoTotal" layoutX="586.0" layoutY="515.0" text="Arrecadação total: 0" textFill="WHITE">
            <font>
                <Font size="44.0" />
            </font></Label>

        <Label fx:id="lblIngressosVendidos" layoutX="579.0" layoutY="446.0" text="Ingressos vendidos: 0" textFill="WHITE">
            <font>
                <Font size="46.0" />
            </font></Label>

        <Button layoutX="723.0" layoutY="831.0" onAction="#voltarIngressos" prefHeight="81.0" prefWidth="164.0" text="Voltar" textFill="#2500ff">
            <font>
                <Font size="38.0" />
            </font></Button>

    </children>

</AnchorPane>