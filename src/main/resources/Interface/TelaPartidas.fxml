<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.ColorAdjust?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="768.0" prefWidth="1024.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Interface.TelaPartidas">

   <children>

      <ImageView fitHeight="1080.0" fitWidth="1920.0"
                 layoutX="-717.0" layoutY="-112.0"
                 pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../assets/stadium2.jpg" />
         </image>
         <effect>
            <GaussianBlur />
         </effect>
      </ImageView>

      <Rectangle id="background-capa"
                 height="717.0"
                 layoutX="148.0"
                 layoutY="36.0"
                 width="700.0"
                 smooth="false"
                 stroke="#2f1f1f"
                 strokeType="INSIDE"
                 strokeWidth="0.0">
         <effect>
            <ColorAdjust />
         </effect>
         <fill>
            <LinearGradient endX="1.0"
                            endY="0.5142857142857142"
                            startX="0.8047619047619048">
               <stops>
                  <Stop>
                     <color>
                        <Color red="0.0313725508749485"
                               green="0.0470588244497776"
                               blue="0.10588235408067703" />
                     </color>
                  </Stop>
                  <Stop offset="1.0">
                     <color>
                        <Color red="0.029999999329447746"
                               green="0.04516666755080223"
                               blue="0.10000000149011612"
                               opacity="0.5632184147834778" />
                     </color>
                  </Stop>
               </stops>
            </LinearGradient>
         </fill>
      </Rectangle>

      <Text fill="#e7e7ee"
            layoutX="381.0"
            layoutY="88.0"
            strokeType="OUTSIDE"
            strokeWidth="0.0"
            text="PARTIDAS"
            textAlignment="JUSTIFY">
         <font>
            <Font size="28.0" />
         </font>
      </Text>

      <AnchorPane id="PopupAdicionarSelecao"
                  layoutX="206.0"
                  layoutY="163.0"
                  prefHeight="57.0"
                  prefWidth="517.0">
         <children>
            <Button layoutX="14.0"
                    layoutY="16.0"
                    mnemonicParsing="false"
                    onAction="#cadastrarPartida"
                    prefHeight="26.0"
                    prefWidth="141.0"
                    text="Cadastrar" />

            <Button layoutX="167.0"
                    layoutY="16.0"
                    mnemonicParsing="false"
                    onAction="#editarPartida"
                    prefHeight="26.0"
                    prefWidth="126.0"
                    text="Editar" />

            <Button layoutX="310.0"
                    layoutY="16.0"
                    mnemonicParsing="false"
                    onAction="#excluirPartida"
                    prefHeight="26.0"
                    prefWidth="107.0"
                    text="Excluir" />

            <Button layoutX="431.0"
                    layoutY="16.0"
                    mnemonicParsing="false"
                    onAction="#listarPartidas"
                    prefHeight="26.0"
                    prefWidth="141.0"
                    text="Listar partidas" />
         </children>
      </AnchorPane>

      <Text fill="WHITE" layoutX="274.0" layoutY="308.0" text="Seleção Casa:" />
      <TextField fx:id="txtSelecaoCasa" layoutX="381.0" layoutY="291.0" promptText="Brasil" />

      <Text fill="WHITE" layoutX="274.0" layoutY="355.0" text="Seleção Visitante:" />
      <TextField fx:id="txtSelecaoVisitante" layoutX="381.0" layoutY="338.0" promptText="Argentina" />

      <Text fill="WHITE" layoutX="274.0" layoutY="399.0" text="Estádio:" />
      <TextField fx:id="txtEstadio" layoutX="381.0" layoutY="381.0" promptText="Mané Garrincha" />

      <Text fill="WHITE" layoutX="274.0" layoutY="441.0" text="Data:" />
      <TextField fx:id="txtData" layoutX="381.0" layoutY="424.0" promptText="10/06/2026" />

      <Text fill="WHITE" layoutX="274.0" layoutY="480.0" text="Horário:" />
      <TextField fx:id="txtHorario" layoutX="381.0" layoutY="462.0" promptText="20:00" />

      <Text fill="WHITE" layoutX="276.0" layoutY="522.0" text="Fase:" />
      <TextField fx:id="txtFase" layoutX="381.0" layoutY="505.0" promptText="Final" />

      <TextArea fx:id="txtAreaPartidas"
                editable="false"
                layoutX="594.0"
                layoutY="281.0"
                prefHeight="300.0"
                prefWidth="250.0"
                wrapText="true" />

   </children>

   <cursor>
      <Cursor fx:constant="DEFAULT" />
   </cursor>

</AnchorPane>
