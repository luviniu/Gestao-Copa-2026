         </font>
      </Text>

      <TextField fx:id="txtBusca" layoutX="682.0" layoutY="251.0" prefHeight="35.0" prefWidth="540.0" promptText="🔍 Digite o nome ou categoria para pesquisar árbitros instantaneamente..." />

      <TableView fx:id="tabelaArbitro" layoutX="682.0" layoutY="342.0" prefHeight="380.0" prefWidth="540.0">
