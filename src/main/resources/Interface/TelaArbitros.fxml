         <fill>
            <LinearGradient endX="1.0" endY="0.5142857142857142" startX="0.8047619047619048">
               <stops>
                  <Stop>
                     <color>
                        <Color red="0.0313725508749485" green="0.0470588244497776" blue="0.10588235408067703" />
                     </color>
                  </Stop>
                  <Stop offset="1.0">
                     <color>
                        <Color red="0.03" green="0.045" blue="0.1" opacity="0.56" />
                     </color>
                  </Stop>
               </stops>
            </LinearGradient>
         </fill>
      </Rectangle>

      <Text fill="#e7e7ee" layoutX="807.0" layoutY="216.0" strokeType="OUTSIDE" strokeWidth="0.0" text="GESTÃO DE ÁRBITROS" textAlignment="CENTER">
