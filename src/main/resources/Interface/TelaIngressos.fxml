                        <Label style="-fx-text-fill: #24292f; -fx-font-size: 16px; -fx-font-weight: bold;" text="Painel do Operador" />
                        <Label style="-fx-text-fill: #57606a; -fx-font-size: 13px;" text="Selecione um confronto na tabela ao lado, defina a categoria do assento e a quantidade desejada antes de emitir." wrapText="true" />

                        <VBox spacing="12.0" style="-fx-padding: 10px 0 0 0;">
                           <children>
                              <Button fx:id="btnVender" mnemonicParsing="false" onAction="#venderIngresso" prefHeight="50.0" prefWidth="500.0" styleClass="btn-primary-custom" text="Emitir / Vender Ingresso ➔">
                                 <cursor><Cursor fx:constant="HAND" /></cursor>
                              </Button>
                              <Button fx:id="btnVender1" mnemonicParsing="false" onAction="#devolverIngresso" prefHeight="45.0" prefWidth="500.0" styleClass="btn-outline-danger" text="Estornar / Devolver Bilhete">
                                 <cursor><Cursor fx:constant="HAND" /></cursor>
                              </Button>

                              <HBox prefHeight="20.0" /> <Button mnemonicParsing="false" onAction="#abrirRelatorio" prefHeight="45.0" prefWidth="500.0" style="-fx-border-color: #0969da; -fx-text-fill: #0969da;" styleClass="btn-secondary-custom" text="📊 Abrir Relatório Financeiro">
                              <cursor><Cursor fx:constant="HAND" /></cursor>
                           </Button>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

               </children>
            </VBox>

         </children>
      </HBox>

   </children>
