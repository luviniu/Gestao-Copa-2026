<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.ColorAdjust?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1080.0" prefWidth="1920.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Interface.TelaPartidas">

   <children>
      <ImageView fitHeight="1080.0" fitWidth="1920.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../assets/stadium2.jpg" />
         </image>
         <effect>
            <GaussianBlur />
         </effect>
      </ImageView>

      <Rectangle id="background-capa" height="760.0" layoutX="460.0" layoutY="160.0" smooth="false" stroke="#2f1f1f" strokeType="INSIDE" strokeWidth="0.0" width="1000.0">
         <effect>
            <ColorAdjust />
         </effect>
         <fill>
            <LinearGradient endX="1.0" endY="0.5142857142857142" startX="0.8047619047619048">
               <stops>
                  <Stop>
                     <color>
                        <Color red="0.0313725508749485" green="0.0470588244497776" blue="0.10588235408067703" />
                     </color>
                  </Stop>
                  <Stop offset="1.0">
                     <color>
                        <Color red="0.03" green="0.045" blue="0.1" opacity="0.75" />
                     </color>
                  </Stop>
               </stops>
            </LinearGradient>
         </fill>
      </Rectangle>

      <Text fill="#e7e7ee" layoutX="890.0" layoutY="220.0" strokeType="OUTSIDE" strokeWidth="0.0" text="PARTIDAS" textAlignment="CENTER">
         <font>
            <Font size="32.0" />
         </font>
      </Text>

      <TextField fx:id="txtBusca" layoutX="510.0" layoutY="260.0" prefHeight="35.0" prefWidth="900.0" promptText="🔍 Digite para pesquisar partidas por país, estádio, fase ou status..." />

      <TableView fx:id="tabelaPartidas" layoutX="510.0" layoutY="310.0" prefHeight="480.0" prefWidth="900.0">
         <columns>
            <TableColumn fx:id="colCasa" prefWidth="130.0" text="Casa" />
            <TableColumn fx:id="colVisitante" prefWidth="130.0" text="Visitante" />
            <TableColumn fx:id="colPlacar" prefWidth="90.0" text="Placar" />
            <TableColumn fx:id="colEstadio" prefWidth="150.0" text="Estádio" />
            <TableColumn fx:id="colData" prefWidth="100.0" text="Data" />
            <TableColumn fx:id="colHorario" prefWidth="80.0" text="Hora" />
            <TableColumn fx:id="colFase" prefWidth="120.0" text="Fase" />
            <TableColumn fx:id="colStatus" prefWidth="95.0" text="Status" />
         </columns>
      </TableView>

      <HBox layoutX="510.0" layoutY="810.0" prefHeight="50.0" prefWidth="900.0" spacing="20.0" stylesheets="@style.css">
         <children>
            <Button mnemonicParsing="false" onAction="#handleBotaoCadastrar" prefHeight="35.0" prefWidth="160.0" stylesheets="@style.css" text="Agendar Partida" />
            <Button mnemonicParsing="false" onAction="#handleBotaoEditar" prefHeight="35.0" prefWidth="140.0" stylesheets="@style.css" text="Editar Horário" />
            <Button mnemonicParsing="false" onAction="#handleBotaoRegistrarResultado" prefHeight="35.0" prefWidth="180.0" stylesheets="@style.css" text="Registrar Placar" />
            <Button mnemonicParsing="false" onAction="#handleBotaoExcluir" prefHeight="35.0" prefWidth="120.0" stylesheets="@style.css" text="Excluir" />
            <Button mnemonicParsing="false" onAction="#listarPartidas" prefHeight="35.0" prefWidth="120.0" stylesheets="@style.css" text="Atualizar Lista" />
         </children>
      </HBox>
   </children>
   <cursor>
      <Cursor fx:constant="DEFAULT" />
   </cursor>
</AnchorPane>
