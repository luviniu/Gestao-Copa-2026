                        <TableColumn fx:id="colInfoJogo" prefWidth="220.0" text="Confronto" />
                        <TableColumn fx:id="colInfoHorario" prefWidth="110.0" style="-fx-alignment: CENTER;" text="Horário" />
                        <TableColumn fx:id="colInfoData" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Data" />
                        <TableColumn fx:id="colInfoLocal" prefWidth="250.0" text="Estádio / Arena" />
                        <TableColumn fx:id="colInfoCapacidade" prefWidth="230.0" style="-fx-alignment: CENTER;" text="Capacidade Máxima" />
                        <TableColumn fx:id="colInfoVendidos" prefWidth="238.0" style="-fx-alignment: CENTER; -fx-font-weight: bold;" text="Ingressos Emitidos" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>

                  <HBox alignment="CENTER_RIGHT">
                     <children>
                        <Button mnemonicParsing="false" onAction="#voltarTela" prefHeight="45.0" prefWidth="160.0" styleClass="btn-secondary-dark" text="Voltar ao Início">
                           <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                     </children>
                  </HBox>

               </children>
            </VBox>

            <VBox prefWidth="530.0" spacing="25.0">
               <children>

                  <VBox spacing="15.0" style="-fx-padding: 25px;" styleClass="main-card-pane">
                     <children>
                        <Label style="-fx-text-fill: #24292f; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-transform: uppercase;" text="Setorização de Bilheteria" />

                        <VBox style="-fx-background-color: #f6f8fa; -fx-padding: 15px; -fx-background-radius: 6px; -fx-border-color: #d0d7de;">
                           <children>
                              <Label style="-fx-text-fill: #57606a; -fx-font-size: 11px; -fx-font-weight: bold;" text="FAIXA DE CATEGORIAS" />
                              <Label style="-fx-text-fill: #24292f; -fx-font-size: 16px; -fx-font-weight: 800;" text="Categoria 1 (VIP) à Categoria 4" />
                           </children>
                        </VBox>

                        <VBox style="-fx-background-color: #ddf4ff; -fx-padding: 15px; -fx-background-radius: 6px; -fx-border-color: rgba(9,105,218,0.2);">
                           <children>
