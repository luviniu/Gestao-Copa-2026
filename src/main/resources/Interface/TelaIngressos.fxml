<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1080.0" prefWidth="1920.0" style="-fx-background-color: #f6f8fa;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Interface.TelaIngressos">
   <children>
      <ImageView fitHeight="1080.0" fitWidth="1920.0" opacity="0.70" pickOnBounds="true" preserveRatio="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <image>
            <Image url="@../assets/stadium2.jpg" />
         </image>
         <effect>
            <GaussianBlur radius="8.0" />
         </effect>
      </ImageView>
      <AnchorPane prefHeight="100.0" prefWidth="1920.0" style="-fx-background-color: #ffffff; -fx-border-color: #d0d7de; -fx-border-width: 0 0 1px 0; -fx-effect: dropshadow(three-pass-box, rgba(31,35,40,0.04), 10, 0, 0, 2);">
         <children>
            <Label layoutX="60.0" layoutY="22.0" style="-fx-text-fill: #24292f; -fx-font-size: 22px; -fx-font-weight: 800; -fx-font-family: 'gg sans';" text="SISTEMA CENTRAL DE EMISSÃO DE INGRESSOS - TICKETING HUB" />
            <Label layoutX="60.0" layoutY="55.0" style="-fx-text-fill: #57606a; -fx-font-size: 14px; -fx-font-family: 'gg sans';" text="Controle de vendas de bilheteria, estorno de assentos corporativos, conferência de lotação das arenas e relatórios financeiros." />
         </children>
      </AnchorPane>

      <HBox layoutX="60.0" layoutY="140.0" prefHeight="880.0" prefWidth="1800.0" spacing="30.0">
         <children>

            <VBox prefWidth="1240.0" spacing="25.0" style="-fx-padding: 35px;" styleClass="main-card-pane">
               <children>

                  <Label style="-fx-font-weight: 800; -fx-font-size: 24px; -fx-font-family: 'gg sans'; -fx-text-fill: #24292f;" text="Disponibilidade de Assentos por Partida" />

                  <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f6f8fa; -fx-padding: 15px; -fx-background-radius: 6px; -fx-border-color: #d0d7de;">
                     <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #57606a;" text="BUSCAR CONFRONTO" />
                              <TextField fx:id="txtBuscaPartida" prefHeight="40.0" promptText="Ex: Brasil x Argentina" style="-fx-background-color: #ffffff; -fx-border-color: #d0d7de; -fx-border-radius: 4px;" />
                           </children>
                        </VBox>

                        <VBox prefWidth="250.0" spacing="5.0">
                           <children>
                              <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #57606a;" text="CATEGORIA DE ASSENTO" />
                              <ComboBox fx:id="comboCategoria" prefHeight="40.0" prefWidth="250.0" style="-fx-background-color: #ffffff; -fx-border-color: #d0d7de; -fx-border-radius: 4px;" />
                           </children>
                        </VBox>

                        <VBox prefWidth="150.0" spacing="5.0">
                           <children>
                              <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #57606a;" text="QUANTIDADE" />
                              <TextField fx:id="txtQuantidade" prefHeight="40.0" promptText="1" style="-fx-background-color: #ffffff; -fx-border-color: #d0d7de; -fx-border-radius: 4px;" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <TableView fx:id="tabelaInfoPartida" fixedCellSize="35.0" prefHeight="430.0" prefWidth="1170.0" style="-fx-background-radius: 8px;">
